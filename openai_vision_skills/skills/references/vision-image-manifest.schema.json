{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vision-image-manifest.schema.json",
  "title": "Vision Image Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "source_documents",
    "images"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "source_documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "document_id",
          "source_file"
        ],
        "properties": {
          "document_id": {
            "type": "string"
          },
          "source_file": {
            "type": "string"
          },
          "document_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "image_id",
          "document_id",
          "page_number",
          "image_type",
          "image_path",
          "render_dpi",
          "pixel_width",
          "pixel_height"
        ],
        "properties": {
          "image_id": {
            "type": "string"
          },
          "document_id": {
            "type": "string"
          },
          "source_file": {
            "type": "string"
          },
          "page_number": {
            "type": "integer",
            "minimum": 1
          },
          "sheet_number": {
            "type": "string"
          },
          "image_type": {
            "type": "string",
            "enum": [
              "overview",
              "page",
              "crop",
              "tile"
            ]
          },
          "image_path": {
            "type": "string"
          },
          "render_dpi": {
            "type": "number"
          },
          "pixel_width": {
            "type": "integer",
            "minimum": 1
          },
          "pixel_height": {
            "type": "integer",
            "minimum": 1
          },
          "full_render_pixel_width": {
            "type": "integer",
            "minimum": 1
          },
          "full_render_pixel_height": {
            "type": "integer",
            "minimum": 1
          },
          "page_size_mm": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "width": {
                "type": "number"
              },
              "height": {
                "type": "number"
              }
            }
          },
          "bounds_px": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "x0",
              "y0",
              "x1",
              "y1"
            ],
            "properties": {
              "x0": {
                "type": "number"
              },
              "y0": {
                "type": "number"
              },
              "x1": {
                "type": "number"
              },
              "y1": {
                "type": "number"
              }
            }
          },
          "bounds_page": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "unit": {
                "type": "string",
                "enum": [
                  "pt",
                  "mm",
                  "inch",
                  "unknown"
                ]
              },
              "x0": {
                "type": "number"
              },
              "y0": {
                "type": "number"
              },
              "x1": {
                "type": "number"
              },
              "y1": {
                "type": "number"
              }
            }
          },
          "tile_overlap_fraction": {
            "type": "number",
            "minimum": 0,
            "maximum": 0.9
          },
          "region_label": {
            "type": "string"
          },
          "region_type": {
            "type": "string"
          },
          "scale_text": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
