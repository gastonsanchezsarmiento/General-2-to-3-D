{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vision-page-output.schema.json",
  "title": "Vision Page Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "document_id",
    "page_number",
    "image_ids",
    "extraction_type",
    "text_blocks",
    "fields",
    "tables",
    "warnings",
    "overall_confidence"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "page_number": {
      "type": "integer",
      "minimum": 1
    },
    "image_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model": {
      "type": "string"
    },
    "preset": {
      "type": "string"
    },
    "extraction_type": {
      "type": "string",
      "enum": [
        "ordinary_document_page",
        "form",
        "screenshot",
        "scan",
        "other"
      ]
    },
    "text_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "confidence",
          "source_image_ids"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_image_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "value",
          "confidence",
          "source_image_ids"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {},
          "raw_text": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_image_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "uncertainty_note": {
            "type": "string"
          }
        }
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "table_id",
          "columns",
          "rows",
          "confidence",
          "source_image_ids"
        ],
        "properties": {
          "table_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_image_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overall_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
