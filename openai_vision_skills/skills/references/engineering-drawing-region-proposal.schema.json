{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engineering-drawing-region-proposal.schema.json",
  "title": "Engineering Drawing Region Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "document_id",
    "page_number",
    "source_image_ids",
    "regions",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "page_number": {
      "type": "integer",
      "minimum": 1
    },
    "sheet_number": {
      "type": "string"
    },
    "source_image_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "region_id",
          "region_type",
          "bounds_px",
          "confidence",
          "why_inspect"
        ],
        "properties": {
          "region_id": {
            "type": "string"
          },
          "region_type": {
            "type": "string",
            "enum": [
              "title_block",
              "revision_table",
              "plan",
              "elevation",
              "section",
              "detail",
              "schedule",
              "legend",
              "notes",
              "grid",
              "dimension_zone",
              "key_plan",
              "dense_unknown",
              "other"
            ]
          },
          "label": {
            "type": "string"
          },
          "bounds_px": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "x0",
              "y0",
              "x1",
              "y1"
            ],
            "properties": {
              "x0": {
                "type": "number"
              },
              "y0": {
                "type": "number"
              },
              "x1": {
                "type": "number"
              },
              "y1": {
                "type": "number"
              }
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "why_inspect": {
            "type": "string"
          },
          "suggested_crop_priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
