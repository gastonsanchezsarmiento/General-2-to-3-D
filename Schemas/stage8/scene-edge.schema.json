{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-to-3d.local/schemas/stage8/scene-edge.schema.json",
  "title": "SceneEdge",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "scene_edge_id",
    "run_id",
    "source_scene_node_id",
    "target_scene_node_id",
    "edge_kind",
    "verification_state"
  ],
  "properties": {
    "schema_id": { "const": "stage8/scene-edge" },
    "schema_version": { "const": "v1" },
    "scene_edge_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "run_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "source_scene_node_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "target_scene_node_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "source_stage6_slice_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "edge_kind": {
      "type": "string",
      "enum": ["supports", "spans-between", "belongs-to", "contained-in", "aligned-with", "connected-to", "depends-on", "references-anchor"]
    },
    "source_neutral_relationship_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "topology_role": { "type": "string" },
    "epistemic_status": { "$ref": "../common/base-types.schema.json#/$defs/EpistemicStatus" },
    "verification_state": {
      "type": "string",
      "enum": ["verified", "verified-with-warnings", "partial-failure", "blocked", "human-review-recommended", "unverified"]
    },
    "issue_ids": {
      "type": "array",
      "items": { "$ref": "../common/base-types.schema.json#/$defs/Id" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "../common/evidence-ref.schema.json" }
    },
    "review_status": {
      "type": "string",
      "enum": ["unreviewed", "machine_verified", "machine_warning", "human_review_recommended", "human_approved", "human_corrected"]
    },
    "extensions": { "$ref": "../common/base-types.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}