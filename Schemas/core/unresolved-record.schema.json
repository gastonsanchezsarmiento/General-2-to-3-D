{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-to-3d.local/schemas/core/unresolved-record.schema.json",
  "title": "UnresolvedRecord",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "unresolved_id",
    "run_id",
    "unresolved_type",
    "target_ids",
    "recommended_next_action",
    "may_proceed"
  ],
  "properties": {
    "schema_id": { "const": "core/unresolved-record" },
    "schema_version": { "const": "v1" },
    "unresolved_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "run_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "unresolved_type": { "type": "string", "minLength": 1 },
    "target_ids": {
      "type": "array",
      "items": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
      "minItems": 1
    },
    "blocking_reason": { "type": "string" },
    "recommended_next_action": { "type": "string", "minLength": 1 },
    "may_proceed": { "type": "boolean" },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "../common/evidence-ref.schema.json" }
    },
    "extensions": { "$ref": "../common/base-types.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}