{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-to-3d.local/schemas/core/observation.schema.json",
  "title": "Observation",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "observation_id",
    "run_id",
    "observation_type",
    "supporting_evidence",
    "epistemic_status",
    "confidence_tier"
  ],
  "properties": {
    "schema_id": { "const": "core/observation" },
    "schema_version": { "const": "v1" },
    "observation_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "run_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "task_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "observation_type": { "type": "string", "minLength": 1 },
    "object_family": { "type": "string" },
    "relationship_family": { "type": "string" },
    "page_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "region_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "summary": { "type": "string" },
    "observed_values": {
      "type": "object",
      "additionalProperties": true
    },
    "supporting_evidence": {
      "type": "array",
      "items": { "$ref": "../common/evidence-ref.schema.json" },
      "minItems": 1
    },
    "epistemic_status": { "$ref": "../common/base-types.schema.json#/$defs/EpistemicStatus" },
    "confidence_tier": { "$ref": "../common/base-types.schema.json#/$defs/ConfidenceTier" },
    "linked_candidate_ids": {
      "type": "array",
      "items": { "$ref": "../common/base-types.schema.json#/$defs/Id" }
    },
    "extensions": { "$ref": "../common/base-types.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}