{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-to-3d.local/schemas/stage6/geometry-maturity-registry.schema.json",
  "title": "GeometryMaturityRegistry",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "registry_id",
    "run_id",
    "model_id",
    "items"
  ],
  "properties": {
    "schema_id": { "const": "stage6/geometry-maturity-registry" },
    "schema_version": { "const": "v1" },
    "registry_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "run_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "model_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "target_kind", "geometry_maturity"],
        "properties": {
          "target_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
          "target_kind": {
            "type": "string",
            "enum": ["object", "relationship"]
          },
          "source_stage6_slice_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
          "geometry_maturity": { "$ref": "../common/base-types.schema.json#/$defs/GeometryMaturity" },
          "review_required": { "type": "boolean" },
          "note": { "type": "string" },
          "extensions": { "$ref": "../common/base-types.schema.json#/$defs/Extensions" }
        },
        "additionalProperties": false
      }
    },
    "extensions": { "$ref": "../common/base-types.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}