{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-to-3d.local/schemas/stage6/verification-readiness.schema.json",
  "title": "VerificationReadiness",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "verification_readiness_id",
    "run_id",
    "model_id",
    "may_proceed",
    "overall_readiness_status"
  ],
  "properties": {
    "schema_id": { "const": "stage6/verification-readiness" },
    "schema_version": { "const": "v1" },
    "verification_readiness_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "run_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "model_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "may_proceed": { "type": "boolean" },
    "overall_readiness_status": {
      "type": "string",
      "enum": ["ready", "ready-with-warnings", "partial", "blocked"]
    },
    "ready_slice_ids": {
      "type": "array",
      "items": { "$ref": "../common/base-types.schema.json#/$defs/Id" }
    },
    "blocked_slice_ids": {
      "type": "array",
      "items": { "$ref": "../common/base-types.schema.json#/$defs/Id" }
    },
    "major_blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "extensions": { "$ref": "../common/base-types.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}