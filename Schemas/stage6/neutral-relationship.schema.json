{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-to-3d.local/schemas/stage6/neutral-relationship.schema.json",
  "title": "NeutralRelationship",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "neutral_relationship_id",
    "run_id",
    "relationship_family",
    "source_object_id",
    "target_object_id",
    "evidence_refs",
    "epistemic_status",
    "lineage"
  ],
  "properties": {
    "schema_id": { "const": "stage6/neutral-relationship" },
    "schema_version": { "const": "v1" },
    "neutral_relationship_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "run_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "relationship_family": { "type": "string", "minLength": 1 },
    "source_object_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "target_object_id": { "$ref": "../common/base-types.schema.json#/$defs/Id" },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "../common/evidence-ref.schema.json" },
      "minItems": 1
    },
    "epistemic_status": { "$ref": "../common/base-types.schema.json#/$defs/EpistemicStatus" },
    "conflict_ids": {
      "type": "array",
      "items": { "$ref": "../common/base-types.schema.json#/$defs/Id" }
    },
    "review_status": {
      "type": "string",
      "enum": ["unreviewed", "machine_verified", "machine_warning", "human_approved", "human_corrected"]
    },
    "lineage": {
      "type": "array",
      "items": { "$ref": "../common/base-types.schema.json#/$defs/LineageRef" },
      "minItems": 1
    },
    "extensions": { "$ref": "../common/base-types.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}